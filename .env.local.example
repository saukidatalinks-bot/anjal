# ─────────────────────────────────────────────
# ANJAL VENTURES — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────

# Neon PostgreSQL Database URL
# Get from: https://neon.tech → Create Project → Connection String
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Admin Password (will be hashed automatically on first run)
# Change this to a strong password before deploying!
ADMIN_PASSWORD="YourStrongPassword2026!"

# JWT Secret (generate a random 64-char string)
# Generate: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-at-least-64-characters-long-for-security"

# App URL (your Vercel deployment URL or localhost)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── EmailJS (for contact form emails) ───
# Get from: https://www.emailjs.com (free account)
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=""
NEXT_PUBLIC_EMAILJS_SERVICE_ID=""
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=""

# ─── Vercel Blob Storage (for image uploads) ───
# Automatically set when you add Vercel Blob to your project
# In Vercel: Storage → Create → Blob → Connect to project
BLOB_READ_WRITE_TOKEN=""

# ─── Company Info (defaults, can also be set via Admin) ───
NEXT_PUBLIC_COMPANY_NAME="Anjal Ventures"
NEXT_PUBLIC_COMPANY_EMAIL="anjalventures@gmail.com"
NEXT_PUBLIC_COMPANY_PHONE="+234 000 000 0000"
